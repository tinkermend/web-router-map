# =============================================
# Application
# =============================================
APP_NAME=web-router-map
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# =============================================
# Database
# =============================================
DATABASE_URL=postgresql+asyncpg://aiops:AIOps!1234@127.0.0.1:5432/navai
DATABASE_SCHEMA=navai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# =============================================
# Redis
# =============================================
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_LOCK_TIMEOUT=300
REDIS_LOCK_PREFIX=wrm:lock:

# =============================================
# Playwright
# =============================================
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_SLOW_MO=0
SCREENSHOT_DIR=./screenshots

# =============================================
# Scheduler
# =============================================
SCHEDULER_ENABLED=true
DEFAULT_AUTH_CRON="0 */6 * * *"
DEFAULT_CRAWL_CRON="0 2 * * *"

# =============================================
# Security / Crypto
# =============================================
ENCRYPTION_KEY=replace-with-64-char-hex-key

# =============================================
# Sentry
# =============================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================
# API
# =============================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# =============================================
# Retry
# =============================================
MAX_RETRIES=3
RETRY_DELAY=5
