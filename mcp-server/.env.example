# Prefer MCP_ prefixed variables; DATABASE_* are accepted as fallback.
MCP_DATABASE_URL=postgresql+asyncpg://aiops:AIOps!1234@127.0.0.1:5432/navai
MCP_DATABASE_SCHEMA=navai

MCP_MIN_STABILITY_SCORE=0.7
MCP_FRESHNESS_HOURS=168
MCP_MAX_CANDIDATES_PER_STAGE=20

MCP_SERVER_NAME=web-router-map-context
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8765
MCP_LOG_LEVEL=INFO
